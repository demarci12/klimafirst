---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const title = "Cookie Beállítások | KlimaFirst";
const description = "Cookie beállítások és süti kezelés.";
---
<BaseLayout {title} {description}>
  <Header />
  <main class="container mx-auto py-12 max-w-2xl">
    <h1 class="text-3xl font-bold mb-6">Cookie Beállítások</h1>
    <p>Placeholder tartalom a sütik kezeléséről.</p>
  </main>
  <Footer />
</BaseLayout>
