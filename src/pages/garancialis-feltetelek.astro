---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const title = "Garancialis Feltételek | KlimaFirst";
const description = "Garancialis feltételek a KlimaFirst szerelési munkájára.";
---
<BaseLayout {title} {description}>
  <Header />
  <main class="container mx-auto py-12 max-w-2xl">
    <h1 class="text-3xl font-bold mb-6">Garancialis Feltételek</h1>
    <p>Placeholder tartalom a garancia feltételeiről.</p>
  </main>
  <Footer />
</BaseLayout>
