---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
const title = "Klímakészülékek | Fisher, Fujitsu, Toshiba, Daikin | KlimaFirst";
const description = "Klímakészülékek: Fisher, Fujitsu, Toshiba, Daikin. Kiváló minőség és szakszerű szerelés Budapesten.";
---
<BaseLayout {title} {description}>
  <Header />
  <main class="container mx-auto py-12">
    <h1 class="text-3xl font-bold mb-6">Klímakészülékek</h1>
    <p>1-2 mondatos placeholder tartalom az elérhető klímamárkákról.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-8">
      <a href="/keszulekek/fisher-klima" class="block bg-white rounded shadow p-6 hover:ring-2 hover:ring-primary transition">
        <h2 class="text-xl font-bold mb-2">Fisher Klíma</h2>
        <p>Megbízható Fisher klímák Magyarország szerte.</p>
      </a>
      <a href="/keszulekek/fujitsu-klima" class="block bg-white rounded shadow p-6 hover:ring-2 hover:ring-primary transition">
        <h2 class="text-xl font-bold mb-2">Fujitsu Klíma</h2>
        <p>Prémium Fujitsu klímák kiváló hatásfokkal.</p>
      </a>
      <a href="/keszulekek/toshiba-klima" class="block bg-white rounded shadow p-6 hover:ring-2 hover:ring-primary transition">
        <h2 class="text-xl font-bold mb-2">Toshiba Klíma</h2>
        <p>Energiatakarékos Toshiba klímák.</p>
      </a>
      <a href="/keszulekek/daikin-klima" class="block bg-white rounded shadow p-6 hover:ring-2 hover:ring-primary transition">
        <h2 class="text-xl font-bold mb-2">Daikin Klíma</h2>
        <p>Csúcstechnológiás Daikin megoldások.</p>
      </a>
    </div>
    <a href="/arak" class="inline-block mt-8 bg-primary text-white px-6 py-2 rounded-full font-semibold hover:bg-secondary transition">Árak</a>
  </main>
  <Footer />
</BaseLayout>
