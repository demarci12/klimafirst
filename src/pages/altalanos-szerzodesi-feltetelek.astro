---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const title = "Általános Szerzödési Feltételek | KlimaFirst";
const description = "Általános szerzödési feltételek a KlimaFirst szolgáltatásaihoz.";
---
<BaseLayout {title} {description}>
  <Header />
  <main class="container mx-auto py-12 max-w-2xl">
    <h1 class="text-3xl font-bold mb-6">Általános Szerzödési Feltételek (ÁSZF)</h1>
    <p>Placeholder tartalom az ÁSZF-ről.</p>
  </main>
  <Footer />
</BaseLayout>
