---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
const title = "Klíma Telepítés Budapest | KlimaFirst";
const description = "Professzionális klímaszerelés Budapesten, ingyenes helyszíni felméréssel. +36 20 339 4164";
const schema = {/* Service schema as per spec */};
---
<BaseLayout {title} {description} schema={schema}>
  <Header />
  <main class="container mx-auto py-12">
    <h1 class="text-3xl font-bold mb-6">Klíma Telepítés Budapest</h1>
    <p>1-2 mondatos placeholder tartalom a szolgáltatásról.</p>
    <RelatedPosts tags={["telepites"]} />
    <a href="/kapcsolat" class="inline-block mt-8 bg-secondary text-white px-6 py-2 rounded-full font-semibold hover:bg-primary transition">Kapcsolat</a>
  </main>
  <Footer />
</BaseLayout>
