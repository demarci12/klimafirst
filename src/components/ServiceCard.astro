---
// ServiceCard: reusable UI card component
const { title, description, href } = Astro.props;
---
<div class="bg-white shadow-md rounded-lg p-6 hover:shadow-lg transition-shadow border border-gray-200">
  <h3 class="font-bold text-lg mb-3 text-gray-800">{title}</h3>
  <p class="text-gray-600 mb-4">{description}</p>
  <a href={href} class="text-secondary hover:text-primary transition-colors font-medium">Érdekel</a>
</div>