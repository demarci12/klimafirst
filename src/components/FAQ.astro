---
// FAQ accordion with schema injection
const { items = [], schema } = Astro.props;
---
<section>
  <h2 class="text-xl font-bold mb-4">Gyakori kérdések</h2>
  <div class="space-y-2">
    {items.map((faq, i) => (
      <details class="border rounded" key={i}>
        <summary class="font-semibold cursor-pointer px-4 py-2 bg-gray-50">{faq.q}</summary>
        <div class="px-4 py-2 text-gray-700">{faq.a}</div>
      </details>
    ))}
  </div>
  {schema && <script type="application/ld+json">{JSON.stringify(schema)}</script>}
</section>
