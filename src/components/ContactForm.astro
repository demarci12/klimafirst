---
// Contact form with honeypot
---
<form class="max-w-lg mx-auto bg-white p-6 rounded shadow" name="contact" method="POST" netlify-honeypot="bot-field">
  <input type="hidden" name="form-name" value="contact" />
  <div class="mb-4">
    <label class="block mb-1 font-semibold" for="name">Teljes név*</label>
    <input required name="name" id="name" type="text" class="w-full border rounded px-3 py-2" />
  </div>
  <div class="mb-4">
    <label class="block mb-1 font-semibold" for="phone">Telefonszám*</label>
    <input required name="phone" id="phone" type="tel" class="w-full border rounded px-3 py-2" />
  </div>
  <div class="mb-4">
    <label class="block mb-1 font-semibold" for="email">Email*</label>
    <input required name="email" id="email" type="email" class="w-full border rounded px-3 py-2" />
  </div>
  <div class="mb-4">
    <label class="block mb-1 font-semibold" for="size">Ingatlan mérete (m²)</label>
    <input name="size" id="size" type="number" class="w-full border rounded px-3 py-2" />
  </div>
  <div class="mb-4">
    <label class="block mb-1 font-semibold" for="message">Üzenet</label>
    <textarea name="message" id="message" rows="4" class="w-full border rounded px-3 py-2"></textarea>
  </div>
  <div style="display:none">
    <label>Ne töltse ki ezt a mezőt: <input name="bot-field" /></label>
  </div>
  <button type="submit" class="w-full bg-primary text-white py-2 rounded font-semibold hover:bg-secondary transition">Küldés</button>
</form>
