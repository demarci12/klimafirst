---
// FloatingContact: mobile-only FAB with enhanced design
---
<div class="fixed bottom-6 right-6 z-50 md:hidden">
  <!-- Pulse animation background -->
  <div class="absolute inset-0 bg-secondary rounded-full animate-ping opacity-20"></div>

  <!-- Main FAB -->
  <a href="tel:+36203394164"
     class="relative bg-gradient-to-r from-secondary to-orange-500 text-white rounded-full shadow-2xl p-4 flex items-center justify-center hover:shadow-3xl hover:scale-110 transition-all duration-300 group"
     aria-label="Telefonhívás KlimaFirst">

    <!-- Phone icon -->
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a2 2 0 011.94 1.515l.7 2.8a2 2 0 01-.45 1.95l-1.27 1.27a16.001 16.001 0 006.586 6.586l1.27-1.27a2 2 0 011.95-.45l2.8.7A2 2 0 0121 18.72V21a2 2 0 01-2 2h-1C7.163 23 1 16.837 1 9V8a2 2 0 012-2z" />
    </svg>

    <!-- Tooltip -->
    <div class="absolute bottom-full right-0 mb-2 px-3 py-1 bg-gray-900 text-white text-sm rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap">
      Hívjon most!
      <div class="absolute top-full right-4 w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-gray-900"></div>
    </div>
  </a>

  <!-- Emergency badge -->
  <div class="absolute -top-2 -left-2 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full animate-pulse">
    24/7
  </div>
</div>

<style>
  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(-4px);
    }
    60% {
      transform: translateY(-2px);
    }
  }

  .animate-bounce {
    animation: bounce 1s infinite;
  }
</style>

