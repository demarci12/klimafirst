---
// SEO component: meta tags, OG, Twitter, hreflang, canonical, JSON-LD schema
const { title, description, schema, canonical, isArticle = false } = Astro.props;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, 'https://klimafirst.hu').href;
---
<title>{title} | KlimaFirst – Klímaszerelés Budapest</title>
<meta name="description" content={description}>
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
<meta name="author" content="Juhász Balázs – KlimaFirst">
<meta name="geo.region" content="HU-BU">
<meta name="geo.placename" content="Budapest">
<meta name="geo.position" content="47.4979;19.0402">
<meta name="ICBM" content="47.4979, 19.0402">
<link rel="canonical" href={canonicalUrl}>
<link rel="alternate" hreflang="hu-HU" href={canonicalUrl}>
<link rel="alternate" hreflang="hu" href={canonicalUrl}>
<link rel="alternate" hreflang="x-default" href="https://klimafirst.hu">
<meta property="og:type" content={isArticle ? 'article' : 'website'}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonicalUrl}>
<meta property="og:image" content="https://klimafirst.hu/images/og-default.jpg">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="KlimaFirst – Klímaszerelés Budapest">
<meta property="og:locale" content="hu_HU">
<meta property="og:site_name" content="KlimaFirst">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content="https://klimafirst.hu/images/og-default.jpg">
{schema && <script type="application/ld+json">{JSON.stringify(schema)}</script>}
