---
// DistrictGrid: grid of 23 kerületek
import { keruletek } from '../data/keruletek';
---
<section>
  <h2 class="text-xl font-bold mb-4">Klímaszerelés Budapest mind a 23 kerületében</h2>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    {keruletek.map((k) => (
      <a href={`/budapest/${k.slug}`} class="block p-4 bg-white rounded shadow hover:ring-2 hover:ring-primary transition">
        <div class="font-bold">{k.name}</div>
        <div class="text-xs text-gray-500">{k.landmark}</div>
      </a>
    ))}
  </div>
</section>
